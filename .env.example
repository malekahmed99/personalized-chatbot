# ── LLM ────────────────────────────────────────────────────────────────────
# Absolute path to the quantized GGUF model file
MODEL_PATH=C:\path\to\your\model.gguf

# Absolute path to the directory containing the three tokenizer JSON files
TOKENIZER_PATH=C:\path\to\tokenizer\dir

# Total context window the model supports (tokens)
MODEL_MAX_CONTEXT=8192

# Token budget allocated to conversation history.
# Leaves headroom for the system prompt + generated response.
CHAT_HISTORY_TOKEN_BUDGET=6144

# CPU threads allocated to llama.cpp inference
N_THREADS=8

# GPU layers to offload. 0 = CPU-only. -1 = offload all (requires CUDA build).
N_GPU_LAYERS=0

# Hard cap on tokens the model can generate per response
MAX_NEW_TOKENS=2048

# ── Database ────────────────────────────────────────────────────────────────
DB_URL=postgresql+asyncpg://db_user:db_password@localhost:5432/chatbot

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# IMPORTANT: Change this before deploying. Never commit this value to git.
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
API_PREFIX=/api

# the origins/URLs that the API will be able to receive requests from (frontend).
ALLOWED_ORIGINS=http://localhost:5173
