# Copy this to .env and fill in your keys. Load with `python-dotenv` or
# `export $(cat .env | xargs)` before running the agent/tests.

# Optional -- raises NVD rate limit but CVE lookup works without it
NVD_API_KEY=

# Required for ip_reputation tool -- https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY= "47dc7d1dbbb609d3bc1322cc5ea8eb566319d27a5c54ac45e35c94ec2f7a9563966613bd0d9c4737"

# Required for virustotal_lookup tool -- https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY= "0bda05fc6bf58b20f19f070ac7bc68982553d59e12bf0ce5f8113bf089c95b0d"

# Required for shodan_lookup tool -- https://account.shodan.io/
SHODAN_API_KEY="PDqyc6mIRj2djeEJCR0hYXusqvEgKeDN"

# Required for malwarebazaar_lookup tool -- https://auth.abuse.ch/
MALWAREBAZAAR_API_KEY="9ed3a664d28cb92e06ab34a01a402f3460d8b1af78d553b0"

# Required for url_scan tool -- https://urlscan.io/user/profile/
URLSCAN_API_KEY="019f41d0-c269-74cc-b2dc-5e0fa8d1c8b5"

# Which local model server to use: "llamacpp" (default) or "ollama"
LLM_BACKEND=llamacpp

# Model name/identifier -- for llamacpp this is just a label (any string works,
# the server only ever serves the one model you loaded it with); for ollama
# this must exactly match the name from `ollama list`.
CYBERSENTRY_MODEL=cybersentry

# llama-cpp-python server URL (used when LLM_BACKEND=llamacpp)
# Start the server first with:
#   python -m llama_cpp.server --model /path/to/model.gguf --n_ctx 8192
LLAMACPP_BASE_URL=http://localhost:8000/v1

# Ollama connection (used only when LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://localhost:11434
